{
  "name": "week5-assignment-student",
  "version": "1.0.0",
  "description": "Simple server-rendered site with Node.js and PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:schema": "psql -h $PGHOST -p $PGPORT -U $PGUSER -d $PGDATABASE -f sql/schema.sql",
    "db:seed": "psql -h $PGHOST -p $PGPORT -U $PGUSER -d $PGDATABASE -f sql/seed.sql",
    "db:reset": "npm run db:schema && npm run db:seed"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
