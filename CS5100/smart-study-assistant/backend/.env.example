NODE_ENV=development
HOST=0.0.0.0
PORT=5500
STATIC_DIR=./dist

# Use a long random value for real deployments.
SESSION_SECRET=

# Optional: restrict browser origins when running frontend and backend separately.
CORS_ORIGIN=http://localhost:5173

# At least one provider key is required for model responses.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

QDRANT_HOST=localhost
QDRANT_PORT=6333
EMBEDDING_CACHE_DIR=./.cache/embeddings

# Local demos only. Set DEMO_PASSWORD if enabled.
ENABLE_DEMO_USER=false
DEMO_PASSWORD=
